              {
                "conditions": [
                  {
                    "name": "hyper",
                    "type": "variable_if",
                    "value": 1
                  },
                  {
                    "name": "hyper_sublayer_e",
                    "type": "variable_if",
                    "value": 0
                  }
                ],
                "description": "Toggle Hyper sublayer w",
                "from": {
                  "key_code": "w",
                  "modifiers": {
                    "optional": ["any"]
                  }
                },
                "to": [
                  {
                    "set_variable": {
                      "name": "hyper_sublayer_w",
                      "value": 1
                    }
                  }
                ],
                "to_after_key_up": [
                  {
                    "set_variable": {
                      "name": "hyper_sublayer_w",
                      "value": 0
                    }
                  }
                ],
                "type": "basic"
